# Required — Anthropic API key for Claude analysis.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — GitHub personal access token. Without it the
# API rate limit is 60 req/hr; with it, 5000 req/hr.
GITHUB_TOKEN=

# LLM model selection (preferred). Choose based on intent:
#   fast    — Haiku, ~10× cheaper. For UI iteration, smoke
#             testing, debugging stream/event shape.
#   quality — Sonnet. For deploy and demos.
#   parity  — Sonnet, forced. Use this whenever you measure
#             performance or test prod-equivalent behavior.
# Default if unset: 'quality'.
LLM_MODEL_INTENT=quality

# Deprecated — kept for backwards compatibility with existing
# deploys. Use LLM_MODEL_INTENT instead. Will be removed in
# a future release. Mapping: development → fast,
# production → quality.
# LLM_MODE=production

# Demo mode flag. When 'true', the UI shows the daily quota
# remaining counter and rate-limit messaging. When 'false' or
# unset, the counter is hidden. Used to differentiate the
# public demo deploy from local dev.
NEXT_PUBLIC_IS_DEMO=false
