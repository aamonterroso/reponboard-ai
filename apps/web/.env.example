# Required — Anthropic API key for Claude analysis.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — GitHub personal access token. Without it the
# API rate limit is 60 req/hr; with it, 5000 req/hr.
GITHUB_TOKEN=

# LLM model selection. 'development' uses Haiku (fast/cheap),
# 'production' uses Sonnet (accurate). Default: production.
LLM_MODE=production

# Demo mode flag. When 'true', the UI shows the daily quota
# remaining counter and rate-limit messaging. When 'false' or
# unset, the counter is hidden. Used to differentiate the
# public demo deploy from local dev.
NEXT_PUBLIC_IS_DEMO=false
