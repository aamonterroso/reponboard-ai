{
  "name": "reponboard-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Onboard any codebase in 5 minutes — AI-powered onboarding agent",
  "author": "Allan Monterroso <allan.monterroso1@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/amonterroso/reponboard-ai.git"
  },
  "keywords": [
    "ai",
    "agent",
    "codebase",
    "onboarding",
    "documentation",
    "github",
    "claude",
    "anthropic",
    "developer-tools"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "bench": "tsx --env-file=.env.local scripts/benchmark.ts",
    "bench:summary": "tsx scripts/benchmark-summary.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@reponboard/agent-core": "workspace:*",
    "@types/minimist": "^1.2.5",
    "minimist": "^1.2.8",
    "tsx": "^4.21.0"
  }
}
